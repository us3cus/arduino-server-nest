@baseUrl = http://127.0.0.1:3000

### Root status
GET {{baseUrl}}/
Accept: application/json

### Health
GET {{baseUrl}}/health
Accept: application/json

### Current control mode
GET {{baseUrl}}/api/mode
Accept: application/json

### Switch to manual mode
POST {{baseUrl}}/api/mode
Content-Type: application/json

{
  "mode": "manual"
}

### Switch to auto mode
POST {{baseUrl}}/api/mode
Content-Type: application/json

{
  "mode": "auto"
}

### Device command (4-channel state)
GET {{baseUrl}}/api/device/command
Accept: application/json

### Set LCD text (Arduino shows it)
POST {{baseUrl}}/api/lcd
Content-Type: application/json

{
  "line1": "Hello ESP32",
  "line2": "From Postman"
}

### Clear LCD remote text
POST {{baseUrl}}/api/lcd
Content-Type: application/json

{
  "line1": "",
  "line2": ""
}

### Legacy light relay ON
POST {{baseUrl}}/api/relay
Content-Type: application/json

{
  "relay": 1
}

### Legacy light relay OFF
POST {{baseUrl}}/api/relay
Content-Type: application/json

{
  "relay": 0
}

### Set single channel
POST {{baseUrl}}/api/relay
Content-Type: application/json

{
  "channel": "fan",
  "state": 1
}

### Set multiple channels
POST {{baseUrl}}/api/relay
Content-Type: application/json

{
  "relays": {
    "light": 1,
    "fan": 0,
    "humidifier": 1,
    "pump": 0
  }
}

### Invalid relay payload (validation test)
POST {{baseUrl}}/api/relay
Content-Type: application/json

{
  "channel": "fan",
  "state": 2
}

### Send telemetry
POST {{baseUrl}}/api/device/telemetry
Content-Type: application/json

{
  "device_id": "esp32-growbox-01",
  "relay": 0,
  "relay_light": 0,
  "relay_fan": 0,
  "relay_humidifier": 0,
  "relay_pump": 0,
  "temperature_c": 24.5,
  "humidity": 51
}

### Root status after telemetry
GET {{baseUrl}}/
Accept: application/json

### Get latest DHT values from backend
GET {{baseUrl}}/api/device/dht
Accept: application/json
